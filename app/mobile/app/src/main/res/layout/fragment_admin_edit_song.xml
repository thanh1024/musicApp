<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️ Chỉnh Sửa Bài Hát"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cập nhật các thông tin của bài hát"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Thông Tin Cơ Bản -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Thông Tin Cơ Bản"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editSongTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🎵 Tiêu Đề Bài Hát"
                android:padding="14dp"
                android:text="Chasing Horizons"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editSongArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🎤 Nghệ Sĩ"
                android:padding="14dp"
                android:text="Alex Winter"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editSongAlbum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="💿 Album"
                android:padding="14dp"
                android:text="Neon Sky"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <!-- Phân Loại -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎸 Phân Loại &amp; Tâm Trạng"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/editSongGenre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Thể Loại"
                    android:padding="14dp"
                    android:text="Deep House"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" />

                <EditText
                    android:id="@+id/editSongMood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Tâm Trạng"
                    android:padding="14dp"
                    android:text="Chill"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" />
            </LinearLayout>

            <EditText
                android:id="@+id/editSongDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="⏱️ Thời Lượng"
                android:inputType="number"
                android:padding="14dp"
                android:text="210"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <!-- Phương Tiện & Liên Kết -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎼 Phương Tiện &amp; Liên Kết"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editSongThumbUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🖼️ URL Ảnh Bìa"
                android:inputType="textUri"
                android:padding="14dp"
                android:text="https://example.com/song-cover.jpg"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editSongFileUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🔗 URL File MP3"
                android:inputType="textUri"
                android:padding="14dp"
                android:text="https://example.com/song.mp3"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="18dp">

            <Button
                android:id="@+id/buttonCancelEditSong"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:text="❌ Hủy Bỏ"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonSaveEditSong"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_purple"
                android:text="✅ Lưu Thay Đổi"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
