<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_player_surface"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="14dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="8dp">

        <ImageButton
            android:id="@+id/btnCollapsePlayer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_black_glass"
            android:contentDescription="Thu gọn"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="90" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ĐANG PHÁT TỪ DANH SÁCH"
                android:textColor="#8B96BB"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Nhạc Tâm Trạng"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnPlayerMore"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:contentDescription="More"
            android:src="@drawable/ic_more_vert" />
    </RelativeLayout>

    <FrameLayout
        android:id="@+id/playerCover"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_genre_amber" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlayerSongTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lạc Trôi"
                android:textColor="@color/white"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlayerArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Sơn Tùng M-TP"
                android:textColor="#8D18F3"
                android:textSize="21sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnPlayerFavorite"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="Favorite"
            android:src="@drawable/ic_heart_filled" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekBarPlayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:max="232"
        android:progress="77"
        android:progressTint="#8E2CF5"
        android:thumbTint="#FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-2dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPlayerCurrentTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1:17"
            android:textColor="#9AA8C9"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPlayerTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3:52"
            android:textColor="#9AA8C9"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnShuffle"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="18dp"
            android:background="@android:color/transparent"
            android:contentDescription="Shuffle"
            android:src="@drawable/ic_shuffle" />

        <ImageButton
            android:id="@+id/btnPrevious"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="18dp"
            android:background="@android:color/transparent"
            android:contentDescription="Previous"
            android:src="@drawable/ic_prev" />

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/bg_player_play_btn"
            android:contentDescription="Play"
            android:padding="20dp"
            android:src="@drawable/ic_play" />

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="18dp"
            android:background="@android:color/transparent"
            android:contentDescription="Next"
            android:src="@drawable/ic_next" />

        <ImageButton
            android:id="@+id/btnRepeat"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="Repeat"
            android:src="@drawable/ic_repeat" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_player_bottom_card"
        android:orientation="vertical"
        android:paddingTop="18dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnShareSong"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="44dp"
                android:background="@android:color/transparent"
                android:contentDescription="Share"
                android:src="@drawable/ic_share" />

            <ImageButton
                android:id="@+id/btnAddToPlaylist"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="44dp"
                android:background="@android:color/transparent"
                android:contentDescription="Add playlist"
                android:src="@drawable/ic_playlist_add" />

            <ImageButton
                android:id="@+id/btnDownloadSong"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="44dp"
                android:background="@android:color/transparent"
                android:contentDescription="Download"
                android:src="@drawable/ic_download" />

            <ImageButton
                android:id="@+id/btnLyrics"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="Lyrics"
                android:src="@drawable/ic_lyrics" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvEmotionMode"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_chip_active"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="Phát theo cảm xúc: Thư giãn"
            android:textColor="#8B2CF5"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>