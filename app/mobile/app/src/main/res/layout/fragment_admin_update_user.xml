<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️ Cập Nhật Người Dùng"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cập nhật thông tin tài khoản người dùng"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Thông Tin Cá Nhân -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 Thông Tin Cá Nhân"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editUpdateUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="👤 Tên Đăng Nhập"
                android:padding="14dp"
                android:text="nguyenvana123"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editUpdateFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="📝 Họ Và Tên"
                android:padding="14dp"
                android:text="Nguyễn Văn A"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editUpdateAvatarUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🖼️ Đường Dẫn Ảnh Đại Diện"
                android:inputType="textUri"
                android:padding="14dp"
                android:text="https://images.unsplash.com/photo-158"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <!-- Thông Tin Tài Khoản -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐 Thông Tin Tài Khoản"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editUpdateEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="📧 Email"
                android:inputType="textEmailAddress"
                android:padding="14dp"
                android:text="admin@example.com"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editUpdatePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🔒 Mật Khẩu Mới (Tùy Chọn)"
                android:inputType="textPassword"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <!-- Vai Trò & Quyền Hạn -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍💼 Vai Trò &amp; Quyền Hạn"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editUpdateRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="Vai Trò"
                android:padding="14dp"
                android:text="ROLE_ADMIN"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_inactive"
                android:padding="12dp"
                android:text="⚠️ Lưu Ý: Thay đổi vai trò về ADMIN sẽ cấp đặc quyền đăng nhạc, duyệt dữ liệu và phân quyền hệ thống."
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="18dp">

            <Button
                android:id="@+id/buttonCancelUpdateUser"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:text="❌ Hủy Bỏ"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonSaveUpdateUser"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_purple"
                android:text="✅ Lưu Thay Đổi"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
