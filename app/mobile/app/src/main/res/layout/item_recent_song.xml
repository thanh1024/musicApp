<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="110dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="12dp">

    <FrameLayout
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/imgRecentThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_dark_card"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_waveform"
            android:contentDescription="Song cover" />

        <ImageButton
            android:id="@+id/btnRecentPlay"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_camera_btn"
            android:src="@drawable/ic_play"
            android:padding="6dp"
            android:contentDescription="Play"
            android:clickable="true"
            android:focusable="true" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvRecentTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Title"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tvRecentArtist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Artist"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>

