<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕ Thêm Bài Hát Mới"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Điền đầy đủ thông tin để đăng bài hát lên hệ thống"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Thông Tin Cơ Bản -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Thông Tin Cơ Bản"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editAddSongTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_field"
                android:hint="🎵 Tiêu Đề Bài Hát"
                android:inputType="text"
                android:padding="14dp"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editAddSongArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🎤 Nghệ Sĩ"
                android:inputType="text"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editAddSongAlbum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="💿 Album (Nếu Có)"
                android:inputType="text"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <!-- Phân Loại -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎸 Phân Loại &amp; Tâm Trạng"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/editAddSongGenre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Thể Loại"
                    android:inputType="text"
                    android:padding="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" />

                <EditText
                    android:id="@+id/editAddSongMood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Tâm Trạng"
                    android:inputType="text"
                    android:padding="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" />
            </LinearLayout>

            <EditText
                android:id="@+id/editAddSongDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="⏱️ Thời Lượng (Giây)"
                android:inputType="number"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <!-- Phương Tiện & Liên Kết -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_dark_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎼 Phương Tiện &amp; Liên Kết"
                android:textColor="@color/color_primary_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editAddSongThumbUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🖼️ URL Ảnh Bìa"
                android:inputType="textUri"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/editAddSongFileUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_field"
                android:hint="🔗 URL File MP3"
                android:inputType="textUri"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="18dp">

            <Button
                android:id="@+id/buttonCancelAddSong"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:text="❌ Hủy Bỏ"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonSaveAddSong"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_purple"
                android:text="✅ Lưu &amp; Đăng Bài"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
